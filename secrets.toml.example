# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Secrets — paste this into:  share.streamlit.io → your app →
#                      ⋮ menu → Settings → Secrets   (NOT committed to GitHub)
# TOML format: values in "quotes".
# ─────────────────────────────────────────────────────────────────────────────

# --- REQUIRED: the shared free engine (your key, $0 to run) ---
FREE_PROVIDER  = "gemini"                 # "gemini" or "groq"
GEMINI_API_KEY = "AIza...your_key_here"   # get free: https://aistudio.google.com/apikey

# If you prefer Groq instead, comment the two lines above and use:
# FREE_PROVIDER = "groq"
# GROQ_API_KEY  = "gsk_...your_key_here"   # get free: https://console.groq.com/keys

# --- OPTIONAL ---
# COFFEE_URL   = "https://buymeacoffee.com/your_id"   # shows a tip button if set
# FEEDBACK_URL = "https://forms.gle/your_form"        # or "mailto:you@email.com"
